# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/
.deps_nesso/

# Loose data outputs (parquet dumps from analysis/screening scripts)
*.parquet

# Run outputs / logs
logs/
outputs/
wandb/
*.log

# Trained weights (large; tracked via releases, not git)
*.ckpt
*.pt

# Downloaded binaries (MMseqs2 — see README "MMseqs2" / setup_lumi)
software/

# Core dumps
core
core.*

# Pipeline data (downloaded + generated; large, reproduced by the pipeline).
# Ignore the *contents* (not artifacts/ itself) so git still descends and the
# negation below can re-include the small tokenizer (a model asset, not data).
artifacts/*
!artifacts/tokenizer/
!artifacts/sota/
!artifacts/sota/**/README.md
!artifacts/sota/**/runs.json
!artifacts/sota/**/results/
!artifacts/sota/**/results/**
!artifacts/sota/**/pipeline.env
!artifacts/sota/**/configs/
!artifacts/sota/**/configs/**
# zm_cache/ and *.ckpt live on disk only (large binaries)
artifacts/sota/**/zm_cache/
